# Optional: enable AI product recognition on photo upload (Google Gemini Vision)
GOOGLE_API_KEY=your-google-api-key-here
# or
# GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override the vision model (default: gemini-1.5-flash)
# GEMINI_VISION_MODEL=gemini-1.5-flash

# Flask secret key for flash messages (change in production)
FLASK_SECRET_KEY=your-secret-key

# Portfolio launch: redirect / to /portfolio
SITE_ROOT=portfolio

# Google Analytics 4 for portfolio traffic (format: G-XXXXXXXXXX)
GA4_MEASUREMENT_ID=G-C4PVZ8R1L7

# Token for /portfolio/feedback-admin (defaults to FLASK_SECRET_KEY if unset)
PORTFOLIO_ADMIN_TOKEN=your-admin-token

# Canonical site URL for SEO (sitemap, robots, Open Graph)
PORTFOLIO_SITE_URL=https://jiayi-portfolio.onrender.com
